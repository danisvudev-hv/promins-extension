# Supabase project (Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Google OAuth 2.0 Client ID, type "Web application" (Google Cloud Console → Credentials)
# Authorized redirect URI must be: https://<EXTENSION_ID>.chromiumapp.org/
VITE_GOOGLE_OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
